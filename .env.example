# Optional: require this bearer token on the unified gateway.
# Use the same value with `bun run setup:agents -- --api-key ...`.
GATEWAY_API_KEY=

# Optional: run published GHCR images instead of locally built images.
FREEAI_QWEN_IMAGE=ghcr.io/kravchenski/freeqwenapi/qwen:latest
FREEAI_GATEWAY_IMAGE=ghcr.io/kravchenski/freeqwenapi/gateway:latest
FREEAI_DEEPSEEK_IMAGE=ghcr.io/kravchenski/freeqwenapi/deepseek:latest
FREEAI_KIMI_IMAGE=ghcr.io/kravchenski/freeqwenapi/kimi:latest

# Host ports. Compose binds them to 127.0.0.1 by default.
GATEWAY_PORT=3263
PORT=3264
