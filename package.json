{
    "name": "qwen-api-proxy",
    "version": "1.0.0",
    "description": "Unified OpenAI-compatible gateway for Qwen Chat, DeepSeek Web, and Kimi Web",
    "author": "kravchenski",
    "license": "MIT",
    "homepage": "https://github.com/kravchenski/FreeQwenApi#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kravchenski/FreeQwenApi.git"
    },
    "bugs": {
        "url": "https://github.com/kravchenski/FreeQwenApi/issues"
    },
    "main": "index.ts",
    "type": "module",
    "packageManager": "bun@1.3.14",
    "engines": {
        "bun": ">=1.2.0"
    },
    "scripts": {
        "start": "bun run index.ts",
        "start:deepseek": "bun run deepseek.ts",
        "start:kimi": "bun run kimi.ts",
        "start:gateway": "bun run gateway.ts",
        "start:full": "bun run scripts/start.ts",
        "start:deepseek:full": "bun run scripts/start.ts --service deepseek",
        "start:kimi:full": "bun run scripts/start.ts --service kimi",
        "dev": "bun --watch index.ts",
        "dev:deepseek": "bun --watch deepseek.ts",
        "dev:kimi": "bun --watch kimi.ts",
        "test": "bun test ./test",
        "audit": "bun audit --production",
        "analyze": "knip --reporter compact",
        "check": "bun build index.ts deepseek.ts kimi.ts gateway.ts --target=bun --external typescript --outdir=.build-check",
        "ci": "bun run check:no-js && bun run analyze && bun run test && bun run check",
        "check:no-js": "bun run scripts/check-no-js.ts",
        "example:stream": "bun run examples/openai-sdk/streaming.ts",
        "example:simple": "bun run examples/openai-sdk/simple.ts",
        "example:system": "bun run examples/openai-sdk/system-message.ts",
        "example:image": "bun run examples/openai-sdk/image-analysis.ts",
        "example:conversation": "bun run examples/openai-sdk/conversation.ts",
        "example:compatibility": "bun run examples/openai-sdk/openai-compatibility.ts",
        "example:direct": "bun run examples/direct-api/fetch-example.ts",
        "example:axios": "bun run examples/direct-api/axios-example.ts",
        "example:file-upload": "bun run examples/file-upload/upload-example.ts",
        "example:streaming-test": "bun run examples/streaming-test.ts",
        "auth": "bun run scripts/auth.ts",
        "auth:deepseek": "bun run scripts/deepseek-auth.ts",
        "auth:kimi": "bun run scripts/kimi-auth.ts",
        "setup:agents": "bun run scripts/setup-agents.ts",
        "setup:pi": "bun run scripts/setup-pi.ts",
        "models:sync": "bun run scripts/sync_models.ts",
        "smoke": "bun run scripts/smoke_test.ts"
    },
    "dependencies": {
        "axios": "^1.9.0",
        "body-parser": "^1.20.2",
        "express": "^4.18.2",
        "morgan": "^1.10.0",
        "multer": "^2.0.0",
        "puppeteer": "^24.31.0",
        "puppeteer-extra": "^3.3.6",
        "puppeteer-extra-plugin-stealth": "^2.11.2",
        "winston": "^3.17.0",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "form-data": "^4.0.2",
        "knip": "^6.16.1",
        "openai": "^4.104.0"
    }
}
