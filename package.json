{
    "name": "qwen-api-proxy",
    "version": "1.0.0",
    "description": "Bun-прокси для доступа к Qwen API через эмуляцию браузера",
    "main": "index.ts",
    "type": "module",
    "packageManager": "bun@1.3.14",
    "engines": {
        "bun": ">=1.2.0"
    },
    "scripts": {
        "start": "bun run index.ts",
        "start:deepseek": "bun run deepseek.ts",
        "start:full": "./start.sh",
        "dev": "bun --watch index.ts",
        "dev:deepseek": "bun --watch deepseek.ts",
        "test": "bun test ./test",
        "check": "bun build index.ts deepseek.ts --target=bun --external typescript --outdir=.build-check",
        "ci": "bun run test && bun run check",
        "example:stream": "bun run examples/openai-sdk/streaming.js",
        "example:simple": "bun run examples/openai-sdk/simple.js",
        "example:system": "bun run examples/openai-sdk/system-message.js",
        "example:image": "bun run examples/openai-sdk/image-analysis.js",
        "example:conversation": "bun run examples/openai-sdk/conversation.js",
        "example:compatibility": "bun run examples/openai-sdk/openai-compatibility.js",
        "example:direct": "bun run examples/direct-api/fetch-example.js",
        "example:axios": "bun run examples/direct-api/axios-example.js",
        "example:file-upload": "bun run examples/file-upload/upload-example.js",
        "example:streaming-test": "bun run examples/streaming-test.js",
        "auth": "bun run scripts/auth.ts",
        "models:sync": "bun run scripts/sync_models.ts",
        "smoke": "bun run scripts/smoke_test.ts"
    },
    "dependencies": {
        "axios": "^1.9.0",
        "body-parser": "^1.20.2",
        "express": "^4.18.2",
        "morgan": "^1.10.0",
        "multer": "^2.0.0",
        "puppeteer": "^24.31.0",
        "puppeteer-extra": "^3.3.6",
        "puppeteer-extra-plugin-stealth": "^2.11.2",
        "winston": "^3.17.0"
    },
    "devDependencies": {
        "ali-oss": "^6.23.0",
        "form-data": "^4.0.2",
        "openai": "^4.104.0"
    }
}
